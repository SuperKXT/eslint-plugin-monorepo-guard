{
	"name": "eslint-plugin-monorepo-guard",
	"version": "0.0.1",
	"description": "ESLint rules to enforce package boundaries in a monorepo",
	"author": "Saad Khan",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/SuperKXT/eslint-plugin-monorepo-guard"
	},
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./build/index.d.ts",
				"default": "./build/index.js"
			},
			"require": {
				"types": "./build/index.d.cts",
				"default": "./build/index.cjs"
			}
		}
	},
	"main": "./build/index.cjs",
	"types": "./build/index.d.ts",
	"files": [
		"build"
	],
	"scripts": {
		"build": "tsup",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepublishOnly": "pnpm typecheck && pnpm build && pnpm test"
	},
	"peerDependencies": {
		"eslint": ">=9.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@typescript-eslint/parser": "^8.57.1",
		"eslint": "^9.0.0",
		"tsup": "^8.0.0",
		"typescript": "^5.5.0",
		"vitest": "^2.0.0"
	},
	"keywords": [
		"eslint",
		"eslintplugin",
		"eslint-plugin",
		"plugin",
		"monorepo",
		"turbo",
		"truborepo",
		"yarn",
		"lerna",
		"pnpm",
		"nx",
		"workspaces",
		"relative",
		"imports",
		"package"
	],
	"engines": {
		"node": "^18.18.0 || ^20.9.0 || >=21.1.0"
	},
	"packageManager": "pnpm@10.32.1"
}
