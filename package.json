{
	"name": "eslint-plugin-monorepo-guard",
	"description": "ESLint rules to enforce package boundaries in a monorepo",
	"version": "0.0.2",
	"author": "Saad Khan",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.0.0",
		"@typescript-eslint/parser": "^8.57.1",
		"@vitest/eslint-plugin": "^1.6.13",
		"cspell": "^9.7.0",
		"eslint": "^9.0.0",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-eslint-plugin": "^7.3.2",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-n": "^17.24.0",
		"eslint-plugin-only-warn": "^1.2.1",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"tsup": "^8.0.0",
		"typescript": "^5.5.0",
		"typescript-eslint": "^8.57.1",
		"vitest": "^2.0.0"
	},
	"engines": {
		"node": "^18.18.0 || ^20.9.0 || >=21.1.0"
	},
	"exports": {
		".": {
			"import": {
				"types": "./build/index.d.ts",
				"default": "./build/index.js"
			},
			"require": {
				"types": "./build/index.d.cts",
				"default": "./build/index.cjs"
			}
		}
	},
	"files": [
		"build"
	],
	"keywords": [
		"eslint",
		"eslint-plugin",
		"eslintplugin",
		"imports",
		"lerna",
		"monorepo",
		"nx",
		"package",
		"plugin",
		"pnpm",
		"relative",
		"turbo",
		"turborepo",
		"workspaces",
		"yarn"
	],
	"license": "MIT",
	"main": "./build/index.cjs",
	"packageManager": "pnpm@10.32.1",
	"peerDependencies": {
		"eslint": ">=9.0.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/SuperKXT/eslint-plugin-monorepo-guard"
	},
	"scripts": {
		"build": "tsup",
		"format": "pnpm dlx syncpack format && prettier --write --log-level silent .",
		"lint": "eslint . --max-warnings=0 --fix && pnpm format && pnpm spellcheck",
		"prepublishOnly": "pnpm typecheck && pnpm build && pnpm test",
		"spellcheck": "cspell . --quiet",
		"test": "vitest run",
		"test:watch": "vitest",
		"tsc": "tsc",
		"typecheck": "tsc --noEmit"
	},
	"type": "module",
	"types": "./build/index.d.ts"
}
