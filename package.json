{
  "name": "eslint-plugin-monorepo-guard",
  "version": "2.0.0",
  "description": "ESLint rules to enforce package boundaries in a monorepo",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "monorepo",
    "yarn",
    "workspaces",
    "lerna",
    "relative",
    "package"
  ],
  "author": "Wes Johnson",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/sterlingwes/eslint-plugin-monorepo-cop"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "require": "./build/index.cjs"
    }
  },
  "main": "./build/index.cjs",
  "types": "./build/index.d.ts",
  "files": [
    "build"
  ],
  "engines": {
    "node": "^18.18.0 || ^20.9.0 || >=21.1.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run build && npm test"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
